rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function hasElevatedAccess() {
      return hasRole('admin') || hasRole('staff');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /canonicalRecords/{recordId} {
      allow read: if true;
      allow write: if hasElevatedAccess();
    }

    match /featuredInventory/{itemId} {
      allow read: if true;
      allow create: if hasElevatedAccess() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow update: if hasElevatedAccess() ||
        (isSignedIn() &&
          resource.data.ownerId == request.auth.uid &&
          request.resource.data.ownerId == request.auth.uid);
      allow delete: if hasElevatedAccess() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /users/{userId}/inventory/{itemId} {
      allow read, write: if isOwner(userId) || hasElevatedAccess();
    }

    match /SignupRequests/{requestId} {
      allow create: if true;
      allow read: if hasElevatedAccess();
      allow update, delete: if false;
    }

    match /NewsletterSubscriptions/{subscriptionId} {
      allow create: if true;
      allow read: if hasElevatedAccess();
      allow update, delete: if false;
    }
  }
}