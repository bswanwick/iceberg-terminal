# Comma-separated admin emails for server-side role enforcement.
AUTH_ALLOWED_ADMIN_EMAILS=

# Comma-separated origin allowlist for callable Functions CORS.
AUTH_ALLOWED_ORIGINS=http://localhost:5173

# eBay Browse API server-side credentials.
# eBay portal mapping:
# - App ID (Client ID) -> EBAY_CLIENT_ID
# - Cert ID (Client Secret) -> EBAY_CLIENT_SECRET
# - Dev ID is not required for Browse API client-credentials OAuth.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=SANDBOX
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENDUSERCTX=
EBAY_ACCEPT_LANGUAGE=